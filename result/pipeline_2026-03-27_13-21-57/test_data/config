api_key: YOUR_GROQ_API_KEY
auto_learn_apply_on_verified_hits: true
auto_learn_context_size: 2
auto_learn_dictionary: true
auto_learn_min_len: 2
backoff_multiplier: 2.0
base_url: https://api.groq.com/openai/v1
collocation_corpus_paths:
- data/japanese/label/label.txt
- data/japanese/test/test.txt
collocation_weight: 3.5
collocation_window_size: 4
dict_confidence_threshold: 1
dict_recheck_margin: 1
disable_keep_choice: true
disable_llm_on_rate_limit: true
embedding_score_weight: 2.5
enable_collocation_score: true
enable_embedding_score_in_dict: false
enable_llm_select: true
enable_no_dict_detector: true
enable_pos_filter: true
force_change_on_llm_uncertain: true
homophones_file: data/japanese/dictionary/homophones.json
initial_backoff: 2.0
llm_recheck_dict: true
llm_recheck_min_score: 2
llm_skip_tokens:
- はい
- あ
- あの
- えっと
- うーん
- えー
max_api_retries: 3
max_backoff: 60.0
max_completion_tokens: 400
model: qwen/qwen3-32b
no_dict_adaptive_similarity_floor: 0.7
no_dict_auto_learn_from_llm: true
no_dict_auto_learn_min_hits: 1
no_dict_avoid_short_words: false
no_dict_delegate_to_llm: true
no_dict_enable_pos_guard: false
no_dict_enable_span_guard: false
no_dict_force_when_detector_ok: true
no_dict_max_len_delta: 4
no_dict_max_span_len: 8
no_dict_min_reading_similarity: 0.55
no_dict_pre_normalization_rules:
- pattern: (?<![\u4e00-\u9fff々ヶ])醫師ました(?![\u4e00-\u9fff々ヶ])
  repl: いたしました
- pattern: (?<![\u4e00-\u9fff々ヶ])医師ました(?![\u4e00-\u9fff々ヶ])
  repl: いたしました
- pattern: (?<![\u4e00-\u9fff々ヶ])夜宜し(?![\u4e00-\u9fff々ヶ])
  repl: よろし
- pattern: (?<![\u4e00-\u9fff々ヶ])あり難う(?![\u4e00-\u9fff々ヶ])
  repl: ありがとうございます
- pattern: (?i)(?<![\u4e00-\u9fff々ヶ])patches(?![\u4e00-\u9fff々ヶ])
  repl: でも
no_dict_prompt: 'あなたはASR（音声認識）の同音異義語・近音語の誤り修正を行う専門AIです。

  文脈から明らかに不自然な同音・近音の誤りを検知し、適切な漢字や単語に修正してください。


  【修正のガイドライン】

  1) 同音・近音によるASR誤りのみを修正対象とします（言い換え・要約・語順変更は厳禁）。

  2) 前後の文脈や連語関係を見て、より自然な語彙があれば「積極的に」修正してください。

  3) 複数の単語にまたがる誤り（例: 「勝ってきます」→「かかってきます」）も、文脈が自然になるなら修正可能です。

  4) 同音・近音の候補がある場合は必ず置換を選びます（KEEPは使用しません）。

  5) 助詞や形式名詞（こと、もの、ところ、ください、いたします）の過剰な漢字化は避けてください。

  6) 出力は必ず <改>[...] の1行のみです。


  【出力例】

  入力: お手元には解いていないという状態でしょうか。

  出力: <改>[お手元には届いていないという状態でしょうか。]


  入力: 昨日の夜宜しですね。

  出力: <改>[昨日の夜よろしいですね。]


  入力: 絶好の機械を逃す。

  出力: <改>[絶好の機会を逃す。]


  入力: 島田様ですね。

  出力: <改>[島田様ですね。]'
no_dict_require_explicit_homophone: false
no_dict_require_reading_match: true
no_dict_route_unresolved: true
no_dict_sentence_max_edit_chars: 12
no_dict_sentence_min_similarity: 0.9
path:
  label: D:\VJ\LLM-ASR-Error-Correction\data\japanese\label\label.txt
  test_data: D:\VJ\LLM-ASR-Error-Correction\data\japanese\test\test.txt
pos_filter_rules:
  allow:
  - 名詞
  - 動詞
  - 形容詞
  - 形状詞
  - 感動詞
  - 副詞
  deny:
  - 助詞
  - 助動詞
  - 記号
post_normalization_map:
  あり難う: ありがとうございます
  よろしです: よろしいです
  内検: 内見
  勝ってきます: かかってきます
  医師ました: いたしました
  医師ます: いたします
  只今関: ただいま席
  夜宜し: よろし
  家系させ: かけさせ
  工こと: 工事
  御伝染: お電話
  書無し: 書きなし
  梨: なし
  色んな: いろんな
  蟻: あり
  解いていない: 届いていない
  貰って: もらって
  関を外し: 席を外し
  頂いて: いただいて
  頂く: いただく
prioritize_pos_anomaly: true
protected_compounds:
- 了解
reasoning_effort: low
runtime_map_blacklist_path: result/runtime_blacklist_homophone.jsonl
scoring_context_window: 7
skip_filler_in_dict_stage: true
temperature: 0.0
top_p: 0.4
use_groq_sdk: true
use_verified_runtime_map: true
verified_runtime_min_hits: 1
verified_runtime_path: result/runtime_verified_map_homophone.json
